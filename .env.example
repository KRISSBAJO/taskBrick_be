# =========================================================
# TaskBricks Backend Environment Template
# Copy to .env.local for local development or configure via
# your production secret manager/deployment platform.
# =========================================================

# -------------------------
# App
# -------------------------
NODE_ENV=development
APP_NAME=TaskBricks API
PORT=4070
API_PREFIX=api
API_VERSION=1
PUBLIC_API_URL=https://api.taskbricks.com
FRONTEND_URL=http://localhost:3000
SWAGGER_ENABLED=false
TRUST_PROXY=true
REQUEST_BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
CORS_ORIGINS=https://app.taskbricks.com,https://admin.taskbricks.com

# -------------------------
# Database
# -------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/taskbricks?schema=public
DIRECT_DATABASE_URL=
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=30000

# -------------------------
# Redis / Cache / Queue
# -------------------------
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_HEALTH_REQUIRED=false
QUEUE_PREFIX=taskbricks
QUEUE_CONCURRENCY=5
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000

# -------------------------
# Auth / JWT
# Replace all secrets before running the app.
# -------------------------
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------
# Security
# ENCRYPTION_KEY should be a strong secret used for encrypted integration tokens.
# -------------------------
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
COOKIE_SECRET=replace-with-a-long-random-cookie-secret
SESSION_SECRET=replace-with-a-long-random-session-secret
COOKIE_DOMAIN=.taskbricks.com
COOKIE_SECURE=true
PASSWORD_HASH_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
AUTH_EMAIL_VERIFICATION_REQUIRED=true
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_INVITE_TTL_MINUTES=10080
TWO_FACTOR_ISSUER=TaskBricks

# -------------------------
# Rate Limits
# -------------------------
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# -------------------------
# Email
# MAIL_PROVIDER: none | smtp | resend | sendgrid | ses
# -------------------------
MAIL_PROVIDER=resend
MAIL_FROM=noreply@logaxp.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
RESEND_API_KEY=
SENDGRID_API_KEY=

# -------------------------
# Tenant Internal Mail
# Example address: christopher@demo.taskbricks.local
# -------------------------
INTERNAL_MAIL_DOMAIN=taskbricks.local

# -------------------------
# File Storage
# STORAGE_DRIVER: local | s3 | cloudinary
# -------------------------
STORAGE_DRIVER=s3
MAX_UPLOAD_BYTES=10485760
LOCAL_UPLOAD_DIR=./uploads
S3_REGION=us-east-1
S3_BUCKET=taskbricks-prod-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://taskbricks-prod-uploads.s3.amazonaws.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_FOLDER=taskbricks/uploads

# -------------------------
# Realtime
# SOCKET_ADAPTER: memory | redis
# -------------------------
REALTIME_ENABLED=true
SOCKET_CORS_ORIGINS=https://app.taskbricks.com
SOCKET_ADAPTER=redis
WEBSOCKET_PATH=/socket.io

# -------------------------
# Billing
# BILLING_PROVIDER: none | stripe | paystack | paypal
# -------------------------
BILLING_ENABLED=false
BILLING_PROVIDER=none
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=https://app.taskbricks.com/settings/billing
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=https://app.taskbricks.com/settings/billing?checkout=success
PAYSTACK_PORTAL_URL=https://app.taskbricks.com/settings/billing

# -------------------------
# AI
# AI_DEFAULT_PROVIDER: local | openai | anthropic
# -------------------------
AI_ENABLED=false
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_REQUEST_TIMEOUT_MS=60000

# -------------------------
# Integrations
# -------------------------
WEBHOOK_SIGNING_SECRET=replace-with-a-long-random-webhook-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Meeting runtime and reminders
OMOFLOW_BASE_URL=https://meeting-backend-tg9d.onrender.com
OMOFLOW_API_KEY=
OMOFLOW_WEBHOOK_SECRET=
OMOFLOW_RUNTIME_SYNC_ENABLED=false
WHATSAPP_BUSINESS_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCESS_TOKEN=
WHATSAPP_MEETING_REMINDER_TEMPLATE=taskbricks_meeting_reminder
WHATSAPP_MEETING_FOLLOW_UP_TEMPLATE=taskbricks_meeting_follow_up

# -------------------------
# Observability
# LOG_FORMAT: pretty | json
# -------------------------
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=
METRICS_ENABLED=true
METRICS_PATH=/metrics
OTEL_SERVICE_NAME=taskbricks-be
OTEL_EXPORTER_OTLP_ENDPOINT=

# -------------------------
# Compliance / Governance
# -------------------------
AUDIT_RETENTION_DAYS=2555
DATA_EXPORT_BUCKET=taskbricks-prod-exports
IP_ALLOWLIST=

# -------------------------
# Feature Flags
# -------------------------
MAINTENANCE_MODE=false
SIGNUP_ENABLED=true
INVITATIONS_ENABLED=true

# -------------------------
# Local/demo seeding
# Keep disabled in production.
# -------------------------
SEED_DEMO_DATA=false
SEED_PLATFORM_ADMIN=true
SEED_PLATFORM_ADMIN_EMAIL=admin@taskbricks.local
SEED_ADMIN_EMAIL=admin@taskbricks.local
SEED_ADMIN_PASSWORD=replace-with-a-local-demo-password
