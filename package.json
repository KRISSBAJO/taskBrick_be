{
  "name": "taskbricks-be",
  "version": "0.1.0",
  "description": "TaskBricks Enterprise backend API built with NestJS, Swagger, Prisma, and PostgreSQL.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:security": "jest --runInBand test/env.validation.spec.ts",
    "test:contract": "jest --runInBand --passWithNoTests test/contract && npm run frontend:contract",
    "test:e2e": "jest --runInBand --passWithNoTests test/e2e",
    "test:migration": "prisma validate",
    "test:ci": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch",
    "ci:check": "npm run lint && npm run prisma:validate && npm run openapi:check && ts-node scripts/verify-frontend-contract.ts && npm run test:ci && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "rbac:sync": "ts-node scripts/sync-rbac-defaults.ts",
    "openapi:export": "ts-node scripts/export-openapi.ts",
    "openapi:check": "npm run openapi:export && git diff --exit-code -- docs/api/openapi.json",
    "frontend:contract": "npm run openapi:export && ts-node scripts/verify-frontend-contract.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1072.0",
    "@aws-sdk/s3-request-presigner": "^3.1072.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.1",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
